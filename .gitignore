# --- Build / packaging output (the host serves the build; never commit it) ---
builds/

# --- Dependencies / caches (only if tooling is added later) ---
node_modules/
.cache/

# --- Editor / IDE ---
.vscode/
.idea/
*.swp

# --- OS cruft ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / temp ---
*.log

# --- Scratch / dev-only test harnesses (run locally, never shipped or committed) ---
# Exception: test_suite.mjs IS committed — the one suite a fresh clone can run (negation must
# come AFTER the pattern or git ignores it).
test_*.mjs
!test_suite.mjs
